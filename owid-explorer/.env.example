# All of this is OPTIONAL and only used by the agent (Phase 3).
# Charts, search and overlays work with no configuration at all.

# 'anthropic' | 'openai' | 'ollama'
LLM_PROVIDER=anthropic

# Provide the key matching your provider (fork mode). In the hosted demo,
# visitors can instead paste a key in the UI; it stays in localStorage and is
# sent per-request, never logged or persisted server-side.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (fork mode only — the hosted demo can't reach your localhost).
# Never sourced from client headers.
OLLAMA_BASE_URL=http://localhost:11434
